body{
    margin:0;
    padding:0;
    font-family:Arial, Helvetica, sans-serif;
    background:#f4f4f4;
}

.container{
    width:70%;
    margin:40px auto;
    background:white;
    padding:30px;
    border-radius:10px;
    box-shadow:0 0 10px rgba(0,0,0,.2);
}

h1{
    text-align:center;
    color:#2c3e50;
}

textarea{
    width:100%;
    height:150px;
    font-size:16px;
    padding:10px;
    margin-top:15px;
}

button{
    margin-top:20px;
    width:100%;
    padding:15px;
    background:#3498db;
    color:white;
    border:none;
    border-radius:5px;
    font-size:18px;
    cursor:pointer;
}

button:hover{
    background:#2980b9;
}

.step{
    margin-top:15px;
    padding:15px;
    background:#ecf0f1;
    border-left:5px solid #3498db;
}

h3{
    margin:0;
}

p{
    margin-top:8px;
}
